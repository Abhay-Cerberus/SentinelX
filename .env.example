# Rename this file to .env and put your actual tokens inside.
# DO NOT commit .env to version control!

# Your Hugging Face token (make sure it has required permissions for inference)
HF_TOKEN=YOUR_HUGGINGFACE_TOKEN_HERE

# (Optional) You can override the inference base URL or model name if needed
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=Qwen/Qwen2.5-7B-Instruct